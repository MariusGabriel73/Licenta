<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
                        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">

    <changeSet id="20260401080000-1" author="antigravity">
        <createTable tableName="waitlist">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="pacient_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="medic_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="clinica_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="locatie_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="data_preferata" type="${datetimeType}">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="${datetimeType}">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="20260401080000-2" author="antigravity">
        <addForeignKeyConstraint baseColumnNames="pacient_id"
                                 baseTableName="waitlist"
                                 constraintName="fk_waitlist_pacient_id"
                                 referencedColumnNames="id"
                                 referencedTableName="pacient"/>
        <addForeignKeyConstraint baseColumnNames="medic_id"
                                 baseTableName="waitlist"
                                 constraintName="fk_waitlist_medic_id"
                                 referencedColumnNames="id"
                                 referencedTableName="medic"/>
        <addForeignKeyConstraint baseColumnNames="clinica_id"
                                 baseTableName="waitlist"
                                 constraintName="fk_waitlist_clinica_id"
                                 referencedColumnNames="id"
                                 referencedTableName="clinica"/>
        <addForeignKeyConstraint baseColumnNames="locatie_id"
                                 baseTableName="waitlist"
                                 constraintName="fk_waitlist_locatie_id"
                                 referencedColumnNames="id"
                                 referencedTableName="locatie"/>
    </changeSet>
</databaseChangeLog>

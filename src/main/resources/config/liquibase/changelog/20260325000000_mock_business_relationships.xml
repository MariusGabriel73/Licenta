<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Phase 1: Link Medics to Sectii (departments) -->
    <changeSet id="20260325000000-1" author="jhipster" context="faker">
        <update tableName="medic"><column name="sectie_id" valueNumeric="1"/><where>id = 1</where></update>
        <update tableName="medic"><column name="sectie_id" valueNumeric="1"/><where>id = 2</where></update>
        <update tableName="medic"><column name="sectie_id" valueNumeric="2"/><where>id = 3</where></update>
        <update tableName="medic"><column name="sectie_id" valueNumeric="2"/><where>id = 4</where></update>
        <update tableName="medic"><column name="sectie_id" valueNumeric="3"/><where>id = 5</where></update>
    </changeSet>

    <!-- Phase 2: Link Medics to Clinics (ManyToMany) via rel_medic__clinici -->
    <changeSet id="20260325000000-2" author="jhipster" context="faker">
        <!-- Medic 1 -> Clinica 1 -->
        <insert tableName="rel_medic__clinici"><column name="medic_id" valueNumeric="1"/><column name="clinici_id" valueNumeric="1"/></insert>
        <!-- Medic 2 -> Clinica 2, 1 -->
        <insert tableName="rel_medic__clinici"><column name="medic_id" valueNumeric="2"/><column name="clinici_id" valueNumeric="2"/></insert>
        <insert tableName="rel_medic__clinici"><column name="medic_id" valueNumeric="2"/><column name="clinici_id" valueNumeric="1"/></insert>
        <!-- Medic 3 -> Clinica 3, 8 -->
        <insert tableName="rel_medic__clinici"><column name="medic_id" valueNumeric="3"/><column name="clinici_id" valueNumeric="3"/></insert>
        <insert tableName="rel_medic__clinici"><column name="medic_id" valueNumeric="3"/><column name="clinici_id" valueNumeric="8"/></insert>
        <!-- Medic 4 -> Clinica 3 -->
        <insert tableName="rel_medic__clinici"><column name="medic_id" valueNumeric="4"/><column name="clinici_id" valueNumeric="3"/></insert>
        <!-- Medic 5 -> Clinica 8, 9 -->
        <insert tableName="rel_medic__clinici"><column name="medic_id" valueNumeric="5"/><column name="clinici_id" valueNumeric="8"/></insert>
        <insert tableName="rel_medic__clinici"><column name="medic_id" valueNumeric="5"/><column name="clinici_id" valueNumeric="9"/></insert>
    </changeSet>

    <!-- Phase 3: Link Medics to Specializations (ManyToMany) via rel_medic__specializari -->
    <changeSet id="20260325000000-3" author="jhipster" context="faker">
        <!-- Medic 1 -> Cardiologie (1), Medicina Interna (10) -->
        <insert tableName="rel_medic__specializari"><column name="medic_id" valueNumeric="1"/><column name="specializari_id" valueNumeric="1"/></insert>
        <insert tableName="rel_medic__specializari"><column name="medic_id" valueNumeric="1"/><column name="specializari_id" valueNumeric="10"/></insert>
        <!-- Medic 2 -> Neurologie (6) -->
        <insert tableName="rel_medic__specializari"><column name="medic_id" valueNumeric="2"/><column name="specializari_id" valueNumeric="6"/></insert>
        <!-- Medic 3 -> Pediatrie (9) -->
        <insert tableName="rel_medic__specializari"><column name="medic_id" valueNumeric="3"/><column name="specializari_id" valueNumeric="9"/></insert>
        <!-- Medic 4 -> Dermatologie (2) -->
        <insert tableName="rel_medic__specializari"><column name="medic_id" valueNumeric="4"/><column name="specializari_id" valueNumeric="2"/></insert>
        <!-- Medic 5 -> Ortopedie (4) -->
        <insert tableName="rel_medic__specializari"><column name="medic_id" valueNumeric="5"/><column name="specializari_id" valueNumeric="4"/></insert>
    </changeSet>

    <!-- Phase 4: Load Program Data from CSV (Forced Reload) -->
    <changeSet id="20260329180000-1-v2" author="jhipster">
        <delete tableName="program"/>
        <loadData
                  file="config/liquibase/fake-data/program.csv"
                  separator=";"
                  tableName="program"
                  usePreparedStatements="false">
            <column name="id" type="numeric"/>
            <column name="ziua_saptamanii" type="string"/>
            <column name="ora_start" type="timestamp"/>
            <column name="ora_final" type="timestamp"/>
            <column name="medic_id" type="numeric"/>
            <column name="locatie_id" type="numeric"/>
        </loadData>
    </changeSet>

</databaseChangeLog>
